# Required
TELEGRAM_TOKEN=replace-with-telegram-token
OPENAI_API_KEY=replace-with-openai-api-key

# Telegram chat that receives mirrored conversations and can use /reply.
GURU_CHAT_ID=642590466
HISTORY_DIR=.

# Optional: all four values are required to enable Cartesia voice replies.
CARTESIA_API_KEY=
CARTESIA_VERSION=
CARTESIA_MODEL_ID=
CARTESIA_VOICE_ID=
